<Window x:Class="UsbIpClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UsbIpClient"
        mc:Ignorable="d"
        Title="USB/IP LAN Client"
        Height="600" Width="880"
        MinHeight="480" MinWidth="700"
        Background="#F0F0F0">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.15" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#6200EE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3700B3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E009E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- ── Top bar ── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="🔌 " FontSize="28" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="USB/IP LAN Client" FontSize="20" FontWeight="Bold" Foreground="#222222"/>
                    <TextBlock x:Name="TxtVersion" Text="v1.0" FontSize="11" Foreground="#888888"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnInstallDriver"
                        Content="⚙ Instalar Driver"
                        Style="{StaticResource AccentButton}"
                        Click="BtnInstallDriver_Click"
                        Margin="0,0,8,0"/>
                <Button x:Name="BtnScan"
                        Content="🔍 Buscar Servidores"
                        Style="{StaticResource AccentButton}"
                        Click="BtnScan_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- ── Status bar ── -->
        <Border DockPanel.Dock="Bottom" Background="#333333" Padding="8,4" Margin="0,8,0,0">
            <TextBlock x:Name="TxtStatus"
                       Foreground="White"
                       FontSize="12"
                       Text="Listo. Pulsa 'Buscar Servidores' para escanear la red."/>
        </Border>

        <!-- ── Main content ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel – Servers ── -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top"
                           Text="SERVIDORES DETECTADOS"
                           Style="{StaticResource SectionHeader}"/>

                <Border Style="{StaticResource Card}" DockPanel.Dock="Top" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Añadir manualmente:" FontSize="12" Foreground="#555"/>
                        <DockPanel Margin="0,4,0,0">
                            <Button DockPanel.Dock="Right"
                                    Content="➕"
                                    Width="32"
                                    Style="{StaticResource AccentButton}"
                                    Click="BtnAddManual_Click"
                                    Margin="4,0,0,0"/>
                            <TextBox x:Name="TxtManualIp"
                                     PlaceholderText="192.168.1.100"
                                     FontSize="13"
                                     Padding="6,4"
                                     VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <ListBox x:Name="LstServers"
                         SelectionChanged="LstServers_SelectionChanged"
                         FontSize="13"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}"
                                                Margin="{TemplateBinding Margin}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#EDE7F6"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F3EEF8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding IpAddress}" Foreground="#666" FontSize="11"/>
                                <TextBlock FontSize="11" Foreground="#888">
                                    <Run Text="{Binding DeviceCount}"/>
                                    <Run Text="dispositivos"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ── Right panel – Devices ── -->
            <DockPanel Grid.Column="1">
                <TextBlock DockPanel.Dock="Top"
                           Text="DISPOSITIVOS USB DISPONIBLES"
                           Style="{StaticResource SectionHeader}"/>

                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button x:Name="BtnListDevices"
                            DockPanel.Dock="Right"
                            Content="↻ Actualizar"
                            Style="{StaticResource AccentButton}"
                            Click="BtnListDevices_Click"
                            Margin="8,0,0,0"/>
                    <TextBlock x:Name="TxtServerInfo"
                               Text="Selecciona un servidor de la lista"
                               VerticalAlignment="Center"
                               Foreground="#555"
                               FontSize="13"/>
                </DockPanel>

                <!-- Progress -->
                <ProgressBar x:Name="ProgressBar"
                             DockPanel.Dock="Top"
                             Height="4"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="0,0,0,8"/>

                <!-- Device list -->
                <ListView x:Name="LstDevices"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Bus-ID"  Width="70"
                                            DisplayMemberBinding="{Binding BusId}"/>
                            <GridViewColumn Header="VID:PID" Width="90"
                                            DisplayMemberBinding="{Binding DisplayName}"/>
                            <GridViewColumn Header="Clase"   Width="130"
                                            DisplayMemberBinding="{Binding ClassName}"/>
                            <GridViewColumn Header="Velocidad" Width="150"
                                            DisplayMemberBinding="{Binding SpeedText}"/>
                            <GridViewColumn Header="Estado" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsAttached, Converter={x:Static local:BoolToAttachedConverter.Instance}}"
                                                   Foreground="{Binding IsAttached, Converter={x:Static local:BoolToColorConverter.Instance}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Attach / Detach buttons -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button x:Name="BtnAttach"
                            Content="▶ Conectar Dispositivo"
                            Style="{StaticResource AccentButton}"
                            IsEnabled="False"
                            Click="BtnAttach_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnDetach"
                            Content="⏹ Desconectar"
                            IsEnabled="False"
                            Click="BtnDetach_Click"
                            Padding="14,8"/>
                    <Button x:Name="BtnListPorts"
                            Content="📋 Puertos activos"
                            Click="BtnListPorts_Click"
                            Padding="14,8"
                            Margin="8,0,0,0"/>
                </StackPanel>

            </DockPanel>
        </Grid>

    </DockPanel>
</Window>
